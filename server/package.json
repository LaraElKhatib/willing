{
  "name": "willing-server",
  "version": "1.0.0",
  "description": "",
  "license": "MIT",
  "author": "willing",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch --clear-screen=false src/index.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest dev",
    "test:ui": "vitest dev --coverage --ui",
    "db": "docker compose -f docker-compose.yml up",
    "db:test": "docker compose -f docker-compose.test.yml --env-file .env.test up -V",
    "db:test:up": "docker compose -f docker-compose.test.yml --env-file .env.test up -d -V",
    "db:test:down": "docker compose -f docker-compose.test.yml --env-file .env.test down -v",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "type:check": "tsc --noEmit",
    "script:create-admin": "tsx src/scripts/create-admin.ts",
    "script:migrate": "tsx src/scripts/migrate.ts",
    "script:seed": "tsx src/scripts/seed.ts",
    "script:seed-recommendation": "tsx src/scripts/recommendation/seed.ts",
    "script:audit-recommendation": "tsx src/scripts/recommendation/audit.ts",
    "script:recompute-all-embeddings": "tsx src/scripts/recommendation/recompute-all.ts",
    "script:recompute-composite-vectors": "tsx src/scripts/recommendation/recompute-composite.ts",
    "script:verify-embeddings": "tsx src/scripts/recommendation/verify.ts",
    "script:recommendation:generate-cvs": "tsx src/scripts/recommendation/generate-cvs.ts",
    "script:recommendation:run": "tsx src/scripts/recommendation/run.ts",
    "script:test-resend": "tsx src/scripts/test-resend.ts"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.7.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.9",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "eslint-plugin-import-x": "^4.16.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "jose": "^6.1.3",
    "kysely": "^0.28.10",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "openai": "^6.25.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.17.2",
    "resend": "^6.12.2",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  }
}
